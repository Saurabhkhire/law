# ─────────────────────────────────────────────
# SPONSOR INTEGRATIONS (all optional)
# Each has a free built-in alternative shown
# ─────────────────────────────────────────────

# SPONSOR: LexisNexis — legal case law corpus
# ALT: CourtListener free API (auto-used if key empty)
LEXISNEXIS_API_KEY=
LEXISNEXIS_BASE_URL=https://api.lexisnexis.com/v1

# SPONSOR: Filevine — push docs to case management
# ALT: local PDF export (default when key empty)
FILEVINE_API_KEY=
FILEVINE_ORG_ID=

# SPONSOR: HuggingFace — legal-domain embeddings
# ALT: OpenAI text-embedding-3-small (default when false)
HUGGINGFACE_API_KEY=
USE_HUGGINGFACE_EMBEDDINGS=false

# SPONSOR: Norm.AI — compliance rules engine
# ALT: built-in rules engine (default when key empty)
NORMAI_API_KEY=

# SPONSOR: Trust Foundry — AI safety audit layer
# ALT: built-in citation + confidence scorer (default)
TRUST_FOUNDRY_API_KEY=
