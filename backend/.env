OPENAI_API_KEY=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
